# ============================================================
# DB AI Agent - Environment Configuration
# ============================================================

# --- LLM Configuration ---
# Supported providers: google, openai, anthropic
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-api-key-here

# --- Database Configuration ---
# DB_TYPE options: postgresql, mysql, sqlite, mongodb
DB_TYPE=postgresql

# For SQL databases (PostgreSQL, MySQL, SQLite)
# PostgreSQL: postgresql://user:password@host:port/dbname
# MySQL:      mysql+pymysql://user:password@host:port/dbname
# SQLite:     sqlite:///./mydb.sqlite
DB_URI=postgresql://user:password@localhost:5432/mydb

# For MongoDB
MONGO_URI=mongodb://user:password@localhost:27017
MONGO_DB_NAME=mydb

# --- Privacy & Security ---
# Max rows to return in a single query (prevents data leaks)
MAX_ROWS=100
# Columns to always mask (comma-separated)
SENSITIVE_COLUMNS=password,ssn,credit_card,secret,token,api_key

# --- App Config ---
APP_NAME=DB AI Agent
DEBUG=false
